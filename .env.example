# =============================================================================
# Hermes Agent — Environment Variables (copy to ~/.hermes/.env)
# =============================================================================
# After creating ~/.hermes/.env with these values, run:
#   chmod 600 ~/.hermes/.env
#
# TIP: Generate a random secret:
#   openssl rand -base64 32
# =============================================================================

HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=<your-strong-password>
HERMES_DASHBOARD_BASIC_AUTH_SECRET=<run-openssl-rand-to-generate>
